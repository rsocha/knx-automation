            "_yaml": "type: panel\nname: \"🚗 Garage\"\npanel:\n  control:\n    entity: 4/0/0\n    icon: mdi:garage\n    label: Garagentor\n    status:\n      \"1\": Geöffnet\n      \"0\": Geschlossen\n    buttons:\n      - label: Auf\n        icon: mdi:arrow-up-bold\n        entity: 1/2/51\n        hold_seconds: 2\n      - label: Zu\n        icon: mdi:arrow-down-bold\n        entity: 1/2/52\n        hold_seconds: 2\n        color_active: \"255,193,7\"\n  tiles:\n    - name: 4/0/0\n      entity: 1/2/53\n      icon: mdi:garage-variant\n      status:\n        \"0\": { label: \"Nicht zu\", color: \"255,152,0\", badge: \"alert\" }\n        \"1\": { label: \"Geschlossen\", color: \"76,175,80\", badge: \"check-circle\" }\n    - name: Tor offen\n      entity: 4/0/0\n      icon: mdi:garage-open-variant\n      status:\n        \"1\": { label: \"Geöffnet\", color: \"244,67,54\", badge: \"alert\" }\n        \"0\": { label: \"Zu\", color: \"158,158,158\", badge: \"lock\" }\n    - name: Licht Garage\n      entity: 1/4/6\n      icon: mdi:ceiling-light\n      action: toggle\n      send_entity: 1/1/6\n      status:\n        \"1\": { label: \"An\", color: \"255,193,7\" }\n        \"0\": { label: \"Aus\", color: \"158,158,158\" }\n    - name: Nebenraum\n      entity: 1/2/57\n      icon: mdi:ceiling-light\n      action: toggle\n      send_entity: 1/2/58\n      status:\n        \"1\": { label: \"An\", color: \"255,193,7\" }\n        \"0\": { label: \"Aus\", color: \"158,158,158\" }\n  alert:\n    entity: 4/0/1\n    when: \"== 1\"\n    text: \"Achtung: Garagentor ist geöffnet!\"\n    color: \"244,67,54\"\n",
            "panel": {
              "control": {
                "entity": "4/0/0",
                "icon": "garage",
                "label": "Garagentor",
                "status": {
                  "0": "Geschlossen",
