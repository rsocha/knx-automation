{
  "id": "media-player",
  "name": "Media Player (Sonos)",
  "description": "Musikplayer mit Cover, Steuerung und Lautstärke – Play/Stop Toggle",
  "category": "Media",
  "author": "KNX Automation",
  "version": "2.0",
  "width": 340,
  "height": 420,
  "render": "mediaPlayer",
  "inputs": {
    "ko1": { "name": "Titel (A4)", "type": "text", "description": "Aktueller Songtitel" },
    "ko2": { "name": "Interpret (A5)", "type": "text", "description": "Aktueller Interpret" },
    "ko3": { "name": "Album (A6)", "type": "text", "description": "Album bei Musikwiedergabe" },
    "ko13": { "name": "Sender (A3)", "type": "text", "description": "Sendername bei Radio" },
    "ko4": { "name": "Cover URL (A7)", "type": "text", "description": "URL zum Albumcover" },
    "ko5": { "name": "Status (A2)", "type": "number", "description": "1=Play, 2=Paused, 3=Stopped" },
    "ko6": { "name": "Lautstärke (A15)", "type": "number", "description": "0-100 aktueller Wert" },
    "ko7": { "name": "Position (%)", "type": "number", "description": "Track-Position in Prozent (A10)" },
    "ko9": { "name": "Play senden (E4)", "type": "number", "description": "1 senden = Play" },
    "ko14": { "name": "Pause senden (E5)", "type": "number", "description": "1 senden = Pause" },
    "ko15": { "name": "Stop senden (E6)", "type": "number", "description": "1 senden = Stop" },
    "ko10": { "name": "Nächster (E7)", "type": "number", "description": "1 senden = nächster Track" },
    "ko11": { "name": "Vorheriger (E8)", "type": "number", "description": "1 senden = vorheriger Track" },
    "ko12": { "name": "Lautstärke setzen (E9)", "type": "number", "description": "0-100 senden" },
    "ko18": { "name": "Mute senden (E15)", "type": "number", "description": "1=Mute, 0=Unmute" },
    "ko19": { "name": "Mute Status (A20)", "type": "number", "description": "1=Muted" }
  },
  "variables": {
    "var1": { "name": "Test-Titel", "type": "text", "default": "Keine Wiedergabe" },
    "var2": { "name": "Test-Interpret", "type": "text", "default": "" },
    "var3": { "name": "Test-Album", "type": "text", "default": "" },
    "var4": { "name": "Akzentfarbe (R,G,B)", "type": "color", "default": "99,102,241" },
    "var5": { "name": "Hintergrundfarbe (R,G,B)", "type": "color", "default": "15,15,20" },
    "var6": { "name": "Hintergrund Deckkraft (%)", "type": "number", "default": 95 },
    "var7": { "name": "Rahmenfarbe (R,G,B)", "type": "color", "default": "255,255,255" },
    "var8": { "name": "Rahmen Deckkraft (%)", "type": "number", "default": 6 },
    "var12": { "name": "Rahmenstärke (px)", "type": "number", "default": 1 },
    "var10": { "name": "Border-Radius (px)", "type": "number", "default": 20 },
    "var11": { "name": "Cover Border-Radius (px)", "type": "number", "default": 14 }
  }
}
