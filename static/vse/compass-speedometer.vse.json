{
  "id": "compass-speedometer",
  "name": "Compass Speedometer",
  "description": "Kompass mit Geschwindigkeitsanzeige und Richtungspfeilen (außen→innen)",
  "category": "Sensoren",
  "author": "KNX Automation",
  "version": "2.1",
  "width": 200,
  "height": 200,
  "render": "compassSpeedometer",
  "inputs": {
    "ko1": { "name": "Geschwindigkeit", "type": "number" },
    "ko2": { "name": "Richtung Blau (°)", "type": "number" },
    "ko3": { "name": "Richtung Grau (°)", "type": "number" }
  },
  "variables": {
    "var1":  { "name": "Test-Geschwindigkeit", "type": "number", "default": 0.1 },
    "var2":  { "name": "Test-Richtung Blau (°)", "type": "number", "default": 330 },
    "var3":  { "name": "Dezimalstellen", "type": "number", "default": 1 },
    "var4":  { "name": "Pfeil Blau (R,G,B)", "type": "color", "default": "66,133,244" },
    "var5":  { "name": "Pfeil Grau (R,G,B)", "type": "color", "default": "160,160,160" },
    "var6":  { "name": "Richtung anzeigen", "type": "bool", "default": "1" },
    "var7":  { "name": "Hintergrundfarbe (R,G,B)", "type": "color", "default": "30,30,35" },
    "var8":  { "name": "Hintergrund Deckkraft (%)", "type": "number", "default": 90 },
    "var9":  { "name": "Rahmenfarbe (R,G,B)", "type": "color", "default": "255,255,255" },
    "var10": { "name": "Rahmen Deckkraft (%)", "type": "number", "default": 8 },
    "var11": { "name": "Rahmenstärke (px)", "type": "number", "default": 1 },
    "var12": { "name": "Border-Radius (px)", "type": "number", "default": 16 },
    "var13": { "name": "Tick/Text-Farbe (R,G,B)", "type": "color", "default": "255,255,255" },
    "var14": { "name": "Test-Richtung Grau (°)", "type": "number", "default": 290 },
    "var15": { "name": "Wert Schriftgröße", "type": "number", "default": 32 },
    "unit":  { "name": "Einheit", "type": "text", "default": "kn" }
  }
}
